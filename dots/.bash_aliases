#custom aliases
#Git
alias gs='git status'
alias ga='git add'
alias gc='git commit'

#apt
alias install='sudo apt install'
alias search='apt search'
alias update='sudo apt update'
alias remove='sudo apt remove'
alias purge='sudo apt purge'
alias autoremove='sudo apt autoremove'
alias upgrade='sudo apt full-upgrade'
alias show='apt show'
alias list='apt list'

#venvs
alias data='cd ~/mest/projects/data_science && source .env/bin/activate'
alias datas='cd ~/mest/projects/data_science && source .env/bin/activate && jupyter notebook'
alias pyqt='cd ~/mest/projects/pyqt && source .env/bin/activate'
alias tech='cd ~/mest/exercises/python/ && source .env/bin/activate'
alias flaskr='cd ~/mest/exercises/flask_intro && source .env/bin/activate'
alias school='cd ~/projects/unchained && source .env/bin/activate'
alias fact_app='cd ~/mest/exercises/fact_app && source .env/bin/activate'
alias tinfoleak='cd ~/tools/tinfoleak && source .env/bin/activate'
alias smartscreen='cd ~/mest/projects/mtn/smartscreen && source ../.env/bin/activate'
alias advancia='cd ~/mest/projects/advancia/advancia && source ../.env/bin/activate'
alias scraper='cd ~/mest/projects/scraper/ && source .env/bin/activate'

#utilities
alias clean='sudo ~/scripts/mintcleaner.sh'
alias postman='/opt/Postman/Postman &'
alias popcorn='/opt/Popcorn/Popcorn-Time &'
alias bootinfo='sudo /opt/bootscript/bootinfoscript'
alias elec='/opt/Electron/Electron\ API\ Demos &'
alias deezer='python3 ~/deezer.py http://www.deezer.com/en/playlist/3473973642'
alias vectr='/opt/vectr/vectr &'

#quick access
alias projects='cd ~/mest/projects'
alias exercises='cd ~/mest/exercises'
