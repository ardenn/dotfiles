{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

# ── colours & helpers ────────────────────────────────────────────────────────
BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'
step()   { printf "\n${CYAN}${BOLD}[%02d]${RESET} ${BOLD}%s${RESET}\n" "$1" "$2"; }
ok()     { printf "     ${GREEN}✓${RESET}  %s\n" "$1"; }
info()   { printf "     ${BLUE}→${RESET}  %s\n" "$1"; }
warn()   { printf "     ${YELLOW}⚠${RESET}  %s\n" "$1"; }

printf "\n"
printf "  ${CYAN}╔═══════════════════════════════════════════════════════╗${RESET}\n"
printf "  ${CYAN}║${RESET}                                                       ${CYAN}║${RESET}\n"
printf "  ${CYAN}║${RESET}  ${BOLD}~/dotfiles${RESET}  ·  System Configuration                  ${CYAN}║${RESET}\n"
printf "  ${CYAN}║${RESET}  ${DIM}Final setup steps${RESET}                                     ${CYAN}║${RESET}\n"
printf "  ${CYAN}║${RESET}                                                       ${CYAN}║${RESET}\n"
printf "  ${CYAN}╚═══════════════════════════════════════════════════════╝${RESET}\n\n"

set -e

# ── self-running steps ────────────────────────────────────────────────────────

{{- if eq .machineType "workstation" }}
step 1 "Configuring Bluetooth fast connect & auto-reconnect"
sudo tee -a /etc/bluetooth/main.conf <<< "FastConnectable=true"
sudo tee -a /etc/bluetooth/main.conf <<< "ReconnectAttempts=7"
sudo tee -a /etc/bluetooth/main.conf <<< "ReconnectIntervals=1,2,4,8,16,32,64"
ok "Bluetooth reconnect settings applied"

step 2 "Installing Ghostty themes"
GHOSTTY_THEMES_DIR="$HOME/.config/ghostty/themes"
mkdir -p "$GHOSTTY_THEMES_DIR"
if [ -z "$(ls -A "$GHOSTTY_THEMES_DIR" 2>/dev/null)" ]; then
    tmp=$(mktemp -d)
    git clone --depth=1 --filter=blob:none --sparse \
        https://github.com/mbadolato/iTerm2-Color-Schemes.git "$tmp" 2>/dev/null
    git -C "$tmp" sparse-checkout set ghostty 2>/dev/null
    cp "$tmp/ghostty/"* "$GHOSTTY_THEMES_DIR/"
    rm -rf "$tmp"
    ok "Ghostty themes installed"
else
    info "Ghostty themes already present — skipping"
fi
{{- end }}

step 3 "Enabling SSH service"
sudo systemctl enable --now sshd
ok "sshd enabled and running"

step 4 "Generating SSH keypair (ed25519)"
if [ -f "$HOME/.ssh/id_ed25519" ]; then
    info "SSH key already exists at ~/.ssh/id_ed25519 - skipping"
else
    ssh-keygen -t ed25519 -C "$(hostname)" -N "" -f "$HOME/.ssh/id_ed25519"
    ok "Key generated: ~/.ssh/id_ed25519"
fi

step 5 "Adding SSH public key to GitHub"
if gh auth status &>/dev/null 2>&1; then
    gh ssh-key add "$HOME/.ssh/id_ed25519.pub" --title "$(hostname)"
    ok "SSH key added to GitHub as '$(hostname)'"
else
    warn "gh is not authenticated - key not added yet"
    info "Run after setup:  gh auth login"
    info "Then:             gh ssh-key add ~/.ssh/id_ed25519.pub --title \"\$(hostname)\""
fi

{{- if eq .machineType "workstation" }}
step 6 "Configuring power management"
info "AC: no sleep on idle (screen lock only)"
info "Battery: suspend on idle"
info "Power button: suspend"
info "(These preferences are also captured in dconf.ini)"

# ── session-dependent steps (deferred) ───────────────────────────────────────

step 7 "SSH agent - register key (requires active session)"
warn "Cannot run in this context - execute manually after login:"
info "  eval \"\$(ssh-agent -s)\" && ssh-add ~/.ssh/id_ed25519"
{{- end }}

{{- if eq .machineType "server" }}
step 5 "Enabling user linger (user services start at boot)"
loginctl enable-linger "$USER"
ok "Linger enabled for $USER"

step 6 "Enabling podman socket (rootless container API)"
systemctl --user enable --now podman.socket
ok "podman.socket enabled"

step 7 "Enabling Cockpit"
sudo systemctl enable --now cockpit.socket
ok "Cockpit enabled"

step 8 "Enabling fail2ban"
sudo systemctl enable --now fail2ban
ok "fail2ban enabled"
{{- end }}

# ── post-install checklist ────────────────────────────────────────────────────

printf "\n"
printf "  ${CYAN}${BOLD}╔═══════════════════════════════════════════════════════╗${RESET}\n"
printf "  ${CYAN}${BOLD}║${RESET}  📋  POST-INSTALL CHECKLIST                           ${CYAN}${BOLD}║${RESET}\n"
printf "  ${CYAN}${BOLD}╚═══════════════════════════════════════════════════════╝${RESET}\n"
printf "  ${DIM}Complete these steps on first login:${RESET}\n\n"
printf "  [ ]  eval \"\$(ssh-agent -s)\" && ssh-add ~/.ssh/id_ed25519\n"
printf "  [ ]  gh auth login\n"
printf "  [ ]  gh ssh-key add ~/.ssh/id_ed25519.pub --title \"\$(hostname)\"\n"
printf "  [ ]  sudo tailscale up\n"
{{- if eq .machineType "workstation" }}
printf "  [ ]  Copy KeePassXC database from cloud storage\n"
printf "  [ ]  Sign in to Mullvad VPN\n"
printf "  [ ]  Sign in to Google Chrome\n"
printf "  [ ]  Log out and back in  -  ZSH activates as default shell\n"
printf "  [ ]  Log in to GNOME     -  extensions activate on first session\n"
{{- end }}
{{- if eq .machineType "server" }}
printf "  [ ]  systemctl --user status podman.socket\n"
{{- end }}
{{- if eq .nasRole "host" }}
printf "  [ ]  sudo mount -a  (after storage script runs)\n"
printf "  [ ]  sudo exportfs -v  (verify NFS exports)\n"
{{- end }}
{{- if eq .nasRole "client" }}
printf "  [ ]  mount /media/rodgers/nfs/{{ .nasHostname }}  (after Tailscale is up)\n"
{{- end }}
{{- if eq .transcodeRole "quicksync" }}
printf "  [ ]  vainfo  (verify QuickSync VAAPI device is detected)\n"
{{- end }}
printf "\n"
printf "  ${GREEN}${BOLD}Setup complete. Welcome back.${RESET}\n\n"

{{ end }}
