{{- if eq .chezmoi.os "linux" -}}
{{- if eq .machineType "workstation" -}}
#!/bin/bash

# ── colours & helpers ────────────────────────────────────────────────────────
BOLD='\033[1m'; RESET='\033[0m'
GREEN='\033[0;32m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'
step()   { printf "\n${CYAN}${BOLD}[%02d]${RESET} ${BOLD}%s${RESET}\n" "$1" "$2"; }
ok()     { printf "     ${GREEN}✓${RESET}  %s\n" "$1"; }
info()   { printf "     ${BLUE}→${RESET}  %s\n" "$1"; }

printf "\n"
printf "  ${CYAN}┌───────────────────────────────────────────────────┐${RESET}\n"
printf "  ${CYAN}│${RESET}  🧹  Removing Default Packages                     ${CYAN}│${RESET}\n"
printf "  ${CYAN}└───────────────────────────────────────────────────┘${RESET}\n\n"

{{- if eq .chezmoi.osRelease.id "fedora" }}

packages=(
    rhythmbox
    libreoffice-\*
    fedora-chromium-config
)

step 1 "Removing unwanted Fedora defaults"
sudo dnf remove -y "${packages[@]}"
ok "Removed: ${packages[*]}"

{{- end }}

printf "\n"

{{- end }}
{{- end }}
