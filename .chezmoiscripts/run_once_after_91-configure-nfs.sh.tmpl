{{- if eq .chezmoi.os "linux" -}}
{{- if eq .nasRole "client" -}}
#!/bin/bash

# ── colours & helpers ────────────────────────────────────────────────────────
BOLD='\033[1m'; RESET='\033[0m'
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'
step()   { printf "\n${CYAN}${BOLD}[%02d]${RESET} ${BOLD}%s${RESET}\n" "$1" "$2"; }
ok()     { printf "     ${GREEN}✓${RESET}  %s\n" "$1"; }
info()   { printf "     ${BLUE}→${RESET}  %s\n" "$1"; }
warn()   { printf "     ${YELLOW}⚠${RESET}  %s\n" "$1"; }

printf "\n"
printf "  ${CYAN}┌───────────────────────────────────────────────────┐${RESET}\n"
printf "  ${CYAN}│${RESET}  📂  NFS Mount Configuration                      ${CYAN}│${RESET}\n"
printf "  ${CYAN}└───────────────────────────────────────────────────┘${RESET}\n\n"

NAS_EXPORT="{{ .nasHostname }}:/mnt/storage"
MOUNT_POINT="/media/rodgers/nfs/{{ .nasHostname }}"
FSTAB_ENTRY="${NAS_EXPORT} ${MOUNT_POINT} nfs defaults,_netdev,noauto,user,rw 0 0"

step 1 "Creating mount point"
sudo mkdir -p "$MOUNT_POINT"
ok "Mount point ready: ${MOUNT_POINT}"

step 2 "Registering fstab entry"
if grep -qF "$NAS_EXPORT" /etc/fstab; then
    info "Entry already present in /etc/fstab - skipping"
else
    echo "$FSTAB_ENTRY" | sudo tee -a /etc/fstab > /dev/null
    ok "Entry added to /etc/fstab"
fi

printf "\n  ${YELLOW}⚠${RESET}  Requires Tailscale to be connected before mounting.\n"
printf "  ${BLUE}→${RESET}  To mount: ${BOLD}mount ${MOUNT_POINT}${RESET}\n\n"

{{ end }}
{{- end }}
