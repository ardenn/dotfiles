{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

# ── colours & helpers ────────────────────────────────────────────────────────
BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'
step()   { printf "\n${CYAN}${BOLD}[%02d]${RESET} ${BOLD}%s${RESET}\n" "$1" "$2"; }
ok()     { printf "     ${GREEN}✓${RESET}  %s\n" "$1"; }
info()   { printf "     ${BLUE}→${RESET}  %s\n" "$1"; }
warn()   { printf "     ${YELLOW}⚠${RESET}  %s\n" "$1"; }

printf "\n"
printf "  ${CYAN}╔═══════════════════════════════════════════════════════╗${RESET}\n"
printf "  ${CYAN}║${RESET}                                                       ${CYAN}║${RESET}\n"
printf "  ${CYAN}║${RESET}  ${BOLD}~/dotfiles${RESET}  ·  Package Installation                   ${CYAN}║${RESET}\n"
printf "  ${CYAN}║${RESET}  ${DIM}github.com/ardenn${RESET}                                     ${CYAN}║${RESET}\n"
printf "  ${CYAN}║${RESET}                                                       ${CYAN}║${RESET}\n"
printf "  ${CYAN}╚═══════════════════════════════════════════════════════╝${RESET}\n"
printf "\n"

# ── debian ────────────────────────────────────────────────────────────────────
{{- if eq .chezmoi.osRelease.id "debian" }}

step 1 "Updating system packages"
sudo apt update -y && sudo apt full-upgrade -y
ok "System up to date"

set -eufo pipefail

packages=(
    curl
    git
    zsh
    htop
    gnupg
    openssl
    fzf
    zoxide
    gh
    openssh-server
)

step 2 "Installing packages"
sudo apt install -y "${packages[@]}"
ok "Packages installed"

{{- if eq .machineType "workstation" }}
{{ if eq .chezmoi.arch "amd64" }}
step 3 "Installing Google Chrome"
trap "rm -rf google-chrome-stable_current_amd64.deb" EXIT
wget https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
sudo apt install ./google-chrome-stable_current_amd64.deb
ok "Chrome installed"
{{ end }}

step 4 "Installing Mullvad VPN"
trap "rm -rf mullvad.deb" EXIT
wget -O mullvad.deb https://mullvad.net/download/app/deb/latest/
sudo apt install -y mullvad.deb
ok "Mullvad installed"
{{- end }}

{{- end }}

# ── fedora ────────────────────────────────────────────────────────────────────
{{- if eq .chezmoi.osRelease.id "fedora" }}
set -eufo pipefail

step 1 "Updating system packages"
sudo dnf update -y
ok "System up to date"

step 2 "Enabling third-party repositories"
sudo dnf install -y fedora-workstation-repositories dnf-plugins-core
{{- if eq .machineType "workstation" }}
sudo dnf config-manager setopt google-chrome.enabled=1
sudo dnf copr enable -y scottames/ghostty
sudo dnf config-manager addrepo --from-repofile=https://repository.mullvad.net/rpm/stable/mullvad.repo
{{- end }}
{{- if .isFramework }}
sudo dnf install -y --nogpgcheck \
    --repofrompath 'terra,https://repos.fyralabs.com/terra$releasever' \
    terra-release
{{- end }}
ok "Repositories enabled"

base_packages=(
    curl
    git
    zsh
    zsh-syntax-highlighting
    zsh-autosuggestions
    fzf
    zoxide
    gh
    htop
    gnupg
    util-linux-user
    openssh-server
)

step 3 "Installing packages"
sudo dnf install -y "${base_packages[@]}"
{{- if .isFramework }}
sudo dnf install -y framework-system
{{- end }}
ok "Packages installed"

{{- if eq .machineType "workstation" }}

workstation_packages=(
    google-chrome-stable
    mullvad-vpn
    ghostty
)

step 4 "Installing workstation packages"
sudo dnf install -y "${workstation_packages[@]}"
ok "Workstation packages installed"

flatpaks=(
    com.mattjakeman.ExtensionManager
    org.telegram.desktop
    com.github.marhkb.Pods
    io.gitlab.news_flash.NewsFlash
    io.missioncenter.MissionCenter
    io.github.nozwock.Packet
    com.github.tchx84.Flatseal
    org.keepassxc.KeePassXC
    io.github.celluloid_player.Celluloid
    fr.handbrake.ghb
    org.jellyfin.JellyfinDesktop
    be.alexandervanhee.gradia
    de.wwwtech.gitte
    io.github.anil_e.Codd
    io.github.kolunmi.Bazaar
    net.trowell.typesetter
    org.gnome.SoundRecorder
)

step 5 "Installing Flatpak apps"
flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
flatpak install -y flathub "${flatpaks[@]}"
ok "Flatpaks installed"

{{- else }}

server_packages=(
    nfs-utils
    fail2ban
)

step 4 "Installing server packages"
sudo dnf install -y "${server_packages[@]}"
ok "Server packages installed"

{{- end }}

{{- end }}

{{- if eq .machineType "workstation" }}
step 5 "Installing Brave browser"
curl -fsS https://dl.brave.com/install.sh | sh
ok "Brave installed"

step 6 "Installing Fly.io CLI"
curl -L https://fly.io/install.sh | sh
ok "flyctl installed"
{{- end }}

step 7 "Installing xh (HTTP client)"
curl -sfL https://raw.githubusercontent.com/ducaale/xh/master/install.sh | sh
ok "xh installed"

step 8 "Installing Tailscale"
curl -fsSL https://tailscale.com/install.sh | sh
ok "Tailscale installed"

{{- if eq .machineType "workstation" }}
step 9 "Installing Zed editor"
curl -f https://zed.dev/install.sh | sh
ok "Zed installed"
{{- end }}

step 10 "Installing Starship prompt"
curl -sS https://starship.rs/install.sh | sh
ok "Starship installed"

printf "\n  ${GREEN}${BOLD}Package installation complete.${RESET}\n\n"

{{- end }}
