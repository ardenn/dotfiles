{{- if eq .nasRole "host" -}}
#!/bin/bash

# ── colours & helpers ────────────────────────────────────────────────────────
BOLD='\033[1m'; RESET='\033[0m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'
info()   { printf "     ${BLUE}→${RESET}  %s\n" "$1"; }
warn()   { printf "     ${YELLOW}⚠${RESET}  %s\n" "$1"; }

printf "\n"
printf "  ${CYAN}┌───────────────────────────────────────────────────┐${RESET}\n"
printf "  ${CYAN}│${RESET}  💾  Server Storage Reference                     ${CYAN}│${RESET}\n"
printf "  ${CYAN}└───────────────────────────────────────────────────┘${RESET}\n\n"

warn "Storage configuration is hardware-specific and must be set up manually."
warn "Disk IDs and IP subnets below reflect the current sycamore install."
printf "\n"

info "1. Create mount points:"
printf "       sudo mkdir -p /mnt/disk1 /mnt/disk2 /mnt/storage\n\n"

info "2. Add to /etc/fstab (adjust disk IDs for your hardware):"
printf "\n"
printf "       /dev/disk/by-id/ata-ST2000DM008-2UB102_WFL6AY1C-part1\n"
printf "           /mnt/disk1 ext4 defaults 0 0\n\n"
printf "       /dev/disk/by-id/ata-WDC_WD121KRYZ-01W0RB0_5PJRPUZE-part1\n"
printf "           /mnt/disk2 btrfs defaults 0 0\n\n"
printf "       /mnt/disk1:/mnt/disk2 /mnt/storage\n"
printf "           mergerfs cache.files=off,category.create=pfrd,func.getattr=newest,dropcacheonclose=false 0 0\n\n"

info "3. Add to /etc/exports (adjust subnets for your network):"
printf "\n"
printf "       /mnt/storage\n"
printf "           100.64.0.0/10(rw,sync,no_subtree_check,fsid=1)\n"
printf "           192.168.1.0/24(rw,sync,no_subtree_check,fsid=1)\n"
printf "           192.168.2.0/24(rw,sync,no_subtree_check,fsid=1)\n\n"

info "4. Mount and activate:"
printf "       sudo mount -a\n"
printf "       sudo systemctl enable --now nfs-server.service\n"
printf "       sudo exportfs -ra\n\n"

info "Find disk IDs with:  ls -l /dev/disk/by-id/\n"

{{- end }}
